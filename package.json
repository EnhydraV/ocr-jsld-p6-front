{
  "name": "p6-dfsjs-frontend",
  "version": "1.0.1",
  "description": "Olympic Participation Tracker - React 19 frontend for visualizing Olympic Games data",
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "dev": "vite",
    "build": "tsc && vite build",
